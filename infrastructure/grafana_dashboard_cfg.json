                      "spec": {
                        "dataset": "weather_station",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\r\n  -- Create 10 minutes periods\r\n  time_bucket_gapfill('10m', date_time) AS \"time\",\r\n  \r\n  device_id AS metric,\r\n  \r\n  -- Fill gaps with previous average values\r\n  locf(avg(temperature)) AS \"value\"\r\n\r\nFROM weather_telemetry \r\n\r\nWHERE\r\n  $__timeFilter(date_time)\r\n    AND device_id IN ($chosen_devices)\r\n\r\nGROUP BY \"time\", metric\r\nORDER BY \"time\";",
                        "sql": {
